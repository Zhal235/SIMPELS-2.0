{
    admin off
    persist_config off
    auto_https off
    log {
        format json
    }
    servers {
        trusted_proxies static private_ranges 100.0.0.0/8
    }
}

:{$PORT:3000} {
    log {
        format json
    }

    root * ../app/{$NIXPACKS_SPA_OUTPUT_DIR}
    encode gzip
    file_server

    # Service worker Vite PWA - NEVER cache
    @sw path /sw.js /service-worker.js /workbox-*.js
    header @sw Cache-Control "no-store, no-cache, must-revalidate, proxy-revalidate"
    header @sw Pragma "no-cache"
    header @sw Expires "0"

    # Manifest PWA - jangan cache
    @manifest path /manifest.webmanifest /manifest.json
    header @manifest Cache-Control "no-cache, must-revalidate"
    header @manifest Pragma "no-cache"
    header @manifest Expires "0"

    # index.html - jangan cache agar update terdeteksi
    @html path *.html /
    header @html Cache-Control "no-cache, no-store, must-revalidate"
    header @html Pragma "no-cache"
    header @html Expires "0"

    # Static assets dengan hash (js, css) - cache 1 tahun
    @static path *.js *.css *.woff *.woff2 *.png *.jpg *.svg *.ico
    header @static Cache-Control "public, max-age=31536000, immutable"

    # SPA routing
    try_files {path} /index.html
}
