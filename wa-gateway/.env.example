PORT=3100
REDIS_URL=redis://default:PASSWORD@simpelsredis-qvdxoc:6379
LARAVEL_CALLBACK_URL=https://your-api.domain/api/v1/wa/callback
WA_CALLBACK_SECRET=your-secret-here
WA_QUEUE_NAME=wa_messages
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# Anti-ban: jeda acak antar pesan (dalam milidetik)
WA_MIN_DELAY_MS=3000
WA_MAX_DELAY_MS=8000
# Anti-ban: simulasi mengetik sebelum kirim pesan (true/false)
WA_TYPING_SIMULATION=true
